{
  "solution": "monitoring",
  "version": "1.0.0",
  "description": "AIM Monitoring 솔루션 데이터 스키마. 산업 설비·환경·작업자 안전 데이터 기반 AIoT Monitoring harness 생성 기준",
  "requiredInputs": [
    {
      "id": "site-plan",
      "label": "현장/설비 구성",
      "description": "모니터링 대상 설비, 구역, 휴대/고정 계측기 배치 정보",
      "formats": ["pdf", "png", "docx", "json"],
      "required": true
    },
    {
      "id": "sensor-spec",
      "label": "센서/계측 데이터 명세",
      "description": "초음파, 진동, 열, 가스, SpO2, IMU, 통신 데이터 스키마",
      "formats": ["pdf", "json", "yaml", "csv"],
      "required": true
    },
    {
      "id": "ai-diagnosis-policy",
      "label": "AI 진단 정책",
      "description": "FFT, Autoencoder, LSTM, CNN-LSTM, F1/F2 운영 기준",
      "formats": ["pdf", "json", "docx"],
      "required": false
    },
    {
      "id": "sop-policy",
      "label": "SOP/알림 정책",
      "description": "설비 고장, 유해가스, 과열, 작업자 쓰러짐 발생 시 표준 조치 절차",
      "formats": ["pdf", "docx", "json"],
      "required": false
    }
  ],
  "outputSchema": {
    "monitoringTargets": [
      {
        "id": "string",
        "name": "string",
        "domain": "equipment|environment|worker|ai|operation|system",
        "priority": "low|medium|high|critical"
      }
    ],
    "dataConnectors": [
      {
        "id": "string",
        "name": "string",
        "protocol": "BLE|LTE|Wi-Fi|LoRa|RS-485|API|file",
        "fields": ["string"]
      }
    ],
    "widgetMapping": [
      {
        "widgetId": "string",
        "dataConnector": "string",
        "fieldBindings": {}
      }
    ],
    "gridLayout": [
      {
        "widgetId": "string",
        "x": "number",
        "y": "number",
        "w": "number",
        "h": "number"
      }
    ]
  },
  "analysisSteps": [
    { "step": 1, "label": "AIoT 계측 센서 구성 분석 중...", "duration": 1200 },
    { "step": 2, "label": "설비·환경·작업자 위험 모델 매핑 중...", "duration": 1500 },
    { "step": 3, "label": "20개 Monitoring 위젯 후보 구성 중...", "duration": 1100 },
    { "step": 4, "label": "12그리드 대시보드 harness 생성 완료", "duration": 800 }
  ]
}

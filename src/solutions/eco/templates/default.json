{
  "solution": "eco",
  "templateId": "default",
  "name": "탄소·에너지 기본 레이아웃",
  "description": "에너지 사용량, 탄소 배출량, ESG 목표를 표시하는 AIM ECO 기본 구성",
  "nodes": [
    {
      "id": "node-energy-usage",
      "type": "chartWidget",
      "position": { "x": 80, "y": 60 },
      "data": {
        "widgetId": "energy-usage-trend",
        "label": "에너지 사용 추이",
        "dataConnector": "energy-meter"
      }
    },
    {
      "id": "node-carbon-emissions",
      "type": "kpiWidget",
      "position": { "x": 500, "y": 60 },
      "data": {
        "widgetId": "carbon-emissions",
        "label": "탄소 배출량",
        "dataConnector": "carbon-tracker"
      }
    },
    {
      "id": "node-esg-progress",
      "type": "progressWidget",
      "position": { "x": 80, "y": 320 },
      "data": {
        "widgetId": "esg-target-progress",
        "label": "ESG 목표 달성률",
        "dataConnector": "esg-reporter"
      }
    }
  ],
  "edges": [
    { "id": "e1", "source": "node-energy-usage", "target": "node-carbon-emissions", "type": "smoothstep" },
    { "id": "e2", "source": "node-carbon-emissions", "target": "node-esg-progress", "type": "smoothstep" }
  ]
}

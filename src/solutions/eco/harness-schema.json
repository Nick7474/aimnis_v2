{
  "solution": "eco",
  "version": "1.0.0",
  "description": "AIM ECO 탄소중립·에너지 최적화 솔루션 하네스 생성 기준",
  "requiredInputs": [
    {
      "id": "energy-data",
      "label": "에너지 사용 데이터",
      "description": "설비·건물별 전력 및 연료 사용량",
      "formats": ["csv", "xlsx", "json"],
      "required": true
    },
    {
      "id": "emission-factors",
      "label": "배출계수",
      "description": "에너지원별 온실가스 배출계수",
      "formats": ["csv", "xlsx", "pdf"],
      "required": true
    },
    {
      "id": "esg-policy",
      "label": "ESG 정책",
      "description": "감축 목표와 보고 기준",
      "formats": ["pdf", "docx"],
      "required": false
    }
  ],
  "outputSchema": {
    "carbonBaseline": "number",
    "energyTargets": [
      {
        "sourceId": "string",
        "currentUsage": "number",
        "targetUsage": "number"
      }
    ],
    "widgetMapping": [
      {
        "widgetId": "string",
        "dataConnector": "string",
        "fieldBindings": {}
      }
    ],
    "layoutTemplate": "string"
  },
  "analysisSteps": [
    { "step": 1, "label": "에너지 데이터 분석 중...", "duration": 1200 },
    { "step": 2, "label": "탄소 배출량 산정 중...", "duration": 1300 },
    { "step": 3, "label": "최적화 위젯 구성 중...", "duration": 1000 },
    { "step": 4, "label": "AIM ECO 하네스 생성 완료", "duration": 800 }
  ]
}
